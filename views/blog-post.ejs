      <!-- START: Blog Section -->
      <section class="full-width tj-post-details__area">
         <div class="container">
            <div class="row justify-content-center">
               <div class="col-lg-8">
                  <div class="tj-post-details__container">
                     <article class="tj-single__post">
                        <div class="tj-post__thumb">
                           <img src="<%= postThumb %>" alt="">

                           <a href="#" class="category"><%= postCategory %></a>
                        </div>

                        <div class="tj-post__content">
                           <div class="tj-post__meta entry-meta">
                              <span><i class="fa-light fa-user"></i> <a href="#">By Admin</a></span>
                              <span><i class="fa-light fa-calendar-days"></i> <%= postDate %></span>
                              <span><i class="fa-light fa-comments"></i><a href="#comments">Comments (<%= comments.length %>)</a></span>
                           </div>
                           <h3 class="tj-post__title entry-title"><%= postTitle %></h3>

                           <div class="tj-post__content">
                              <%- postBody %>
                           </div>
                        </div>
                     </article>

                     <!-- post tags & social share -->
                     <div class="single-post_tag_share">
                        <!-- post tags -->
                        <div class="tj_tag">
                           <h4 class="tag__title">Tags:</h4>
                           <div class="tagcloud">
                              <a href="#" rel="tag">Business</a>
                              <a href="#" rel="tag">Analysis</a>
                              <a href="#" rel="tag">Technology</a>
                              <a href="#" rel="tag">Design</a>
                              <a href="#" rel="tag">Strategy</a>
                              <a href="#" rel="tag">Tips</a>
                           </div>
                        </div>
                        <div class="share_link">
                           <a href="#" target="_blank" class="facebook" title="Share this on Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                           <a href="#" class="twitter" title="Share this on Twitter" target="_blank"><i class="fa-brands fa-x-twitter"></i></a>
                           <a href="#" class="linkedin" title="Share this on Linkedin" target="_blank"><i class="fa-brands fa-linkedin-in"></i></a>
                           <a href="#" class="pinterest" title="Pin this Post" target="_blank"><i class="fa-brands fa-pinterest-p"></i></a>
                        </div>
                     </div>

                     <!-- post navigation -->
                     <div class="single-post__navigation">
                        <!-- previous post -->
                        <div class="tj-navigation_post previous">
                           <div class="tj-navigation-post_inner prev_post">
                              <div class="navigation-post_img">
                                 <a href="<%= previousPost.file %>"> <img src="<%= previousPost.image %>" alt=""> </a>
                              </div>
                              <div class="tj-content">
                                 <div class="post_pagination_nav"><i class="fa-regular fa-angle-double-left"></i>previous</div>
                                 <div class="post_pagination_title">
                                    <h5 class="title">
                                       <a href="<%= previousPost.file %>"><%= previousPost.title %></a>
                                    </h5>
                                 </div>
                              </div>
                           </div>
                        </div>

                        <!-- next post -->
                        <div class="tj-navigation_post next">
                           <div class="tj-navigation-post_inner next_post">
                              <div class="tj-content">
                                 <div class="post_pagination_nav">Next<i class="fa-regular fa-angle-double-right"></i>
                                 </div>
                                 <div class="post_pagination_title">
                                    <h5 class="title">
                                       <a href="<%= nextPost.file %>"><%= nextPost.title %></a>
                                    </h5>
                                 </div>
                              </div>
                              <div class="navigation-post_img">
                                 <a href="<%= nextPost.file %>"> <img src="<%= nextPost.image %>" alt=""> </a>
                              </div>
                           </div>
                        </div>
                     </div>

                     <!-- comments area -->
                     <div class="tj-comments__container" id="comments">
                        <div class="tj-comments__wrap">
                           <div class="tj-comment__title">
                              <h3><%= comments.length %> Comment<%= comments.length === 1 ? '' : 's' %></h3>
                           </div>

                           <div class="tj-latest__comments">
                              <% if (commentStatus) { %>
                                 <p style="color:#22c55e; margin-bottom: 20px;"><%= commentStatus %></p>
                              <% } %>
                              <% if (commentError) { %>
                                 <p style="color:#ef4444; margin-bottom: 20px;"><%= commentError %></p>
                              <% } %>
                              <ul>
                                 <% if (comments.length === 0) { %>
                                    <li class="tj__comment">
                                       <div class="tj-comment__wrap">
                                          <div class="comment__text">
                                             <div class="avatar__name">
                                                <h5><a href="javascript:void(0)">No comments yet</a></h5>
                                                <span>Be the first to comment on this post.</span>
                                             </div>
                                          </div>
                                       </div>
                                    </li>
                                 <% } else { %>
                                    <% comments.forEach(function(commentItem) { %>
                                       <li class="tj__comment">
                                          <div class="tj-comment__wrap">
                                             <div class="comment__avatar">
                                                <span><%= commentInitials(commentItem.author) %></span>
                                             </div>
                                             <div class="comment__text">
                                                <div class="avatar__name">
                                                   <h5><a href="<%= commentItem.website || '#' %>"><%= commentItem.author %></a></h5>
                                                   <span><%= new Date(commentItem.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                                </div>
                                                <p><%- commentItem.comment.replace(/\n/g, '<br>') %></p>
                                                <div class="comment__reply" style="display:flex; gap:12px; align-items:center;">
                                                   <a class="comment-reply-link" href="#comment">Reply</a>
                                                   <% if (isAdmin) { %>
                                                      <form action="<%= postFile %>" method="post" onsubmit="return confirm('Delete this comment?');" style="margin:0;">
                                                         <input type="hidden" name="delete_comment_id" value="<%= commentItem.id %>">
                                                         <button type="submit" style="border:0; background:none; color:#ff6b6b; padding:0; cursor:pointer;">Delete</button>
                                                      </form>
                                                   <% } %>
                                                </div>
                                             </div>
                                          </div>
                                       </li>
                                    <% }); %>
                                 <% } %>
                              </ul>
                           </div>
                        </div>

                        <div class="comment-respond">
                           <h3 class="comment-reply-title">
                              <span class="tj-comment__title">Leave a Reply</span>
                           </h3>

                           <form action="<%= postFile %>" method="post" class="tj-post-comment__form">
                              <p class="comment-notes">
                                 <span id="email-notes">Your email address will not be published.</span>
                                 <span class="required-field-message">Required fields are marked <span class="required">*</span></span>
                              </p>

                              <div class="row">
                                 <div class="col-md-6">
                                    <div class="form_group">
                                       <input placeholder="Enter Name" id="author" name="author" type="text" aria-required="true" value="<%= commentForm.author || '' %>">
                                    </div>
                                 </div>
                                 <div class="col-md-6">
                                    <div class="form_group">
                                       <input placeholder="Enter Email" id="email" name="email" type="email" aria-required="true" value="<%= commentForm.email || '' %>">
                                    </div>
                                 </div>
                                 <div class="col-md-12">
                                    <div class="form_group">
                                       <input placeholder="Enter Website" id="url" name="url" type="url" value="<%= commentForm.url || '' %>">
                                    </div>
                                 </div>
                              </div>

                              <div class="row">
                                 <div class="col-md-12">
                                    <div class="form_group">
                                       <textarea class="msg-box" placeholder="Enter Your Comments" id="comment" name="comment" cols="45" rows="8"><%= commentForm.comment || '' %></textarea>
                                    </div>
                                 </div>
                                 <div class="clearfix"></div>
                              </div>

                              <p class="comment-form-cookies-consent">
                                 <input id="wp-comment-cookies-consent" name="wp-comment-cookies-consent" type="checkbox" value="yes">
                                 <label for="wp-comment-cookies-consent">Save my name, email, and website in this browser for the next time I comment.</label>
                              </p>
                              <button class="tj-btn-primary submit" type="submit">Post Comment</button>
                           </form>
                        </div>
                     </div>
                  </div>
               </div>
               <div class="col-lg-4">

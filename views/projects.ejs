<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="site-content">
   <section class="page-header py-5 text-center text-white" style="background: linear-gradient(180deg, #0f0715 0%, #140c1c 100%); padding-top: 140px !important;">
      <div class="container">
         <h1 class="display-4 text-purple">Featured Projects</h1>
         <p class="lead">Showcase of enterprise applications, SaaS platforms, and digital products.</p>
      </div>
   </section>

   <section class="py-5 text-white">
      <div class="container">
         <div class="row">
            <div class="col-lg-4 col-md-6 mb-4">
               <div class="card bg-dark border-purple text-white h-100 shadow">
                  <img src="/assets/img/portfolio/1.jpg" class="card-img-top" alt="SaaS Dashboard">
                  <div class="card-body">
                     <h5 class="card-title text-purple">Automated Enterprise CMS</h5>
                     <p class="card-text text-white-50">Node.js, Express, MongoDB & EJS dynamic admin control panel for content management.</p>
                  </div>
               </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
               <div class="card bg-dark border-purple text-white h-100 shadow">
                  <img src="/assets/img/portfolio/2.jpg" class="card-img-top" alt="E-Commerce API">
                  <div class="card-body">
                     <h5 class="card-title text-purple">High-Scale E-Commerce API</h5>
                     <p class="card-text text-white-50">Microservices backend handling JWT authentication, payment gateway, and order fulfillment.</p>
                  </div>
               </div>
            </div>
            <div class="col-lg-4 col-md-6 mb-4">
               <div class="card bg-dark border-purple text-white h-100 shadow">
                  <img src="/assets/img/portfolio/3.jpg" class="card-img-top" alt="Analytics Platform">
                  <div class="card-body">
                     <h5 class="card-title text-purple">Real-time Analytics Dashboard</h5>
                     <p class="card-text text-white-50">Interactive UI dashboard with data visualization, custom filters, and security controls.</p>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </section>
</main>

<%- include('partials/footer') %>

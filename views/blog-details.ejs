<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="site-content">
   <!-- BREADCRUMB AREA START -->
   <section class="breadcrumb-area" style="background: linear-gradient(180deg, #0f0715 0%, #140c1c 100%); padding: 140px 0 60px;">
      <div class="container">
         <div class="row">
            <div class="col-12 text-center text-white">
               <span class="badge bg-purple px-3 py-2 fs-6 mb-3"><%= blog.category || 'Tutorial' %></span>
               <h1 class="text-purple display-5 font-bold mb-3"><%= blog.title %></h1>
               <div class="d-flex justify-content-center align-items-center gap-4 text-white-50 small">
                  <span><i class="fa-regular fa-user text-purple me-1"></i> <%= blog.author ? blog.author.name : 'Kartik Soni' %></span>
                  <span><i class="fa-regular fa-calendar-days text-purple me-1"></i> <%= new Date(blog.publishedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  <span><i class="fa-regular fa-clock text-purple me-1"></i> <%= blog.readingTime || '5 min read' %></span>
                  <span><i class="fa-regular fa-eye text-purple me-1"></i> <%= blog.views || 0 %> Views</span>
               </div>
            </div>
         </div>
      </div>
   </section>
   <!-- BREADCRUMB AREA END -->

   <!-- BLOG DETAILS AREA START -->
   <section class="blog-details-area py-5 text-white">
      <div class="container">
         <div class="row justify-content-center">
            <div class="col-lg-10">
               <% if (blog.featuredImage) { %>
                  <div class="blog-thumb mb-5 text-center">
                     <img src="<%= blog.featuredImage %>" alt="<%= blog.title %>" class="img-fluid rounded-4 shadow-lg border border-purple" style="max-height: 480px; width: 100%; object-fit: cover;">
                  </div>
               <% } %>

               <div class="blog-post-content fs-5 leading-relaxed text-white-50">
                  <%- blog.content %>
               </div>

               <!-- TAGS & AUTHOR BOX -->
               <div class="border-top border-bottom border-purple py-4 my-5 d-flex flex-wrap align-items-center justify-content-between">
                  <div class="blog-tags mb-3 mb-md-0">
                     <span class="text-white font-bold me-2"><i class="fa-solid fa-tags text-purple me-1"></i> Tags:</span>
                     <% if (blog.tags && blog.tags.length > 0) { %>
                        <% blog.tags.forEach(tag => { %>
                           <a href="/blog?search=<%= encodeURIComponent(tag) %>" class="badge bg-dark border border-purple text-purple text-decoration-none me-1 p-2"><%= tag %></a>
                        <% }) %>
                     <% } else { %>
                        <span class="text-white-50">General</span>
                     <% } %>
                  </div>
                  <div class="blog-share">
                     <span class="text-white font-bold me-2">Share:</span>
                     <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(blog.title) %>&url=<%= encodeURIComponent(process.env.SITE_URL + '/blog/' + blog.slug) %>" target="_blank" class="text-purple me-3 fs-5"><i class="fa-brands fa-twitter"></i></a>
                     <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent(process.env.SITE_URL + '/blog/' + blog.slug) %>&title=<%= encodeURIComponent(blog.title) %>" target="_blank" class="text-purple me-3 fs-5"><i class="fa-brands fa-linkedin-in"></i></a>
                  </div>
               </div>

               <!-- PREVIOUS / NEXT NAVIGATION -->
               <div class="row post-navigation g-4">
                  <div class="col-md-6">
                     <% if (previousPost) { %>
                        <a href="/blog/<%= previousPost.slug %>" class="d-flex align-items-center p-3 rounded-4 bg-dark border border-purple text-decoration-none text-white h-100">
                           <i class="fa-solid fa-arrow-left text-purple fs-4 me-3"></i>
                           <div>
                              <small class="text-white-50 d-block">Previous Post</small>
                              <strong class="text-purple fs-6"><%= previousPost.title %></strong>
                           </div>
                        </a>
                     <% } %>
                  </div>
                  <div class="col-md-6 text-md-end">
                     <% if (nextPost) { %>
                        <a href="/blog/<%= nextPost.slug %>" class="d-flex align-items-center justify-content-end p-3 rounded-4 bg-dark border border-purple text-decoration-none text-white h-100">
                           <div>
                              <small class="text-white-50 d-block">Next Post</small>
                              <strong class="text-purple fs-6"><%= nextPost.title %></strong>
                           </div>
                           <i class="fa-solid fa-arrow-right text-purple fs-4 ms-3"></i>
                        </a>
                     <% } %>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </section>
</main>

<%- include('partials/footer') %>

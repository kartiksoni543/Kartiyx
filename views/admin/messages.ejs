<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Client Inquiries - Admin CMS</title>
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/font-awesome-pro.min.css">
  <style>
    body { background: #0b0512; color: #fff; }
    .sidebar { min-height: 100vh; background: #130a21; border-right: 1px solid rgba(168, 85, 247, 0.2); }
    .nav-link { color: #a0aec0; padding: 12px 20px; font-weight: 500; }
    .nav-link.active, .nav-link:hover { color: #c084fc; background: rgba(168, 85, 247, 0.1); border-radius: 8px; }
    .card-stat { background: #190e2b; border: 1px solid rgba(168, 85, 247, 0.2); border-radius: 16px; }
    .text-purple { color: #c084fc; }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 sidebar p-3">
      <h4 class="text-purple fw-bold mb-4">Kartik CMS</h4>
      <ul class="nav flex-column gap-2">
        <li class="nav-item"><a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-chart-line me-2"></i> Dashboard</a></li>
        <li class="nav-item"><a href="/admin/blogs" class="nav-link"><i class="fa-solid fa-newspaper me-2"></i> Blogs</a></li>
        <li class="nav-item"><a href="/admin/messages" class="nav-link active"><i class="fa-solid fa-envelope me-2"></i> Inquiries</a></li>
        <li class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fa-solid fa-gears me-2"></i> Settings</a></li>
        <li class="nav-item mt-4"><a href="/admin/logout" class="nav-link text-danger"><i class="fa-solid fa-right-from-bracket me-2"></i> Logout</a></li>
      </ul>
    </div>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="mb-4">Client Contact Inquiries</h2>

      <div class="card-stat p-3">
        <table class="table table-dark table-hover mb-0">
          <thead>
            <tr>
              <th>Sender</th>
              <th>Email</th>
              <th>Subject</th>
              <th>Message</th>
              <th>IP & Browser</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (messages && messages.length > 0) { %>
              <% messages.forEach(msg => { %>
                <tr>
                  <td><strong><%= msg.name %></strong></td>
                  <td><a href="mailto:<%= msg.email %>" class="text-purple"><%= msg.email %></a></td>
                  <td><%= msg.subject %></td>
                  <td style="max-width: 250px;"><%= msg.message %></td>
                  <td><small class="text-white-50"><%= msg.ipAddress %><br><%= msg.browser %></small></td>
                  <td><small><%= new Date(msg.createdAt).toLocaleString() %></small></td>
                  <td>
                    <button onclick="deleteMsg('<%= msg._id %>')" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center py-4 text-white-50">No client messages stored yet.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  async function deleteMsg(id) {
    if (!confirm('Delete this client message?')) return;
    try {
      const res = await fetch(`/admin/api/messages/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (res.ok && data.success) {
        window.location.reload();
      } else {
        alert(data.message || 'Error deleting message');
      }
    } catch (err) {
      alert('Network error deleting message');
    }
  }
</script>

</body>
</html>

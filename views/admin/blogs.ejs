<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Manage Blogs - Admin CMS</title>
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/font-awesome-pro.min.css">
  <style>
    body { background: #0b0512; color: #fff; }
    .sidebar { min-height: 100vh; background: #130a21; border-right: 1px solid rgba(168, 85, 247, 0.2); }
    .nav-link { color: #a0aec0; padding: 12px 20px; font-weight: 500; }
    .nav-link.active, .nav-link:hover { color: #c084fc; background: rgba(168, 85, 247, 0.1); border-radius: 8px; }
    .card-stat { background: #190e2b; border: 1px solid rgba(168, 85, 247, 0.2); border-radius: 16px; }
    .text-purple { color: #c084fc; }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 sidebar p-3">
      <h4 class="text-purple fw-bold mb-4">Kartik CMS</h4>
      <ul class="nav flex-column gap-2">
        <li class="nav-item"><a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-chart-line me-2"></i> Dashboard</a></li>
        <li class="nav-item"><a href="/admin/blogs" class="nav-link active"><i class="fa-solid fa-newspaper me-2"></i> Blogs</a></li>
        <li class="nav-item"><a href="/admin/messages" class="nav-link"><i class="fa-solid fa-envelope me-2"></i> Inquiries</a></li>
        <li class="nav-item"><a href="/admin/settings" class="nav-link"><i class="fa-solid fa-gears me-2"></i> Settings</a></li>
        <li class="nav-item mt-4"><a href="/admin/logout" class="nav-link text-danger"><i class="fa-solid fa-right-from-bracket me-2"></i> Logout</a></li>
      </ul>
    </div>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Blog CMS Management</h2>
        <a href="/admin/blogs/create" class="btn btn-purple"><i class="fa-solid fa-plus me-1"></i> Add New Blog</a>
      </div>

      <div class="card-stat p-3">
        <table class="table table-dark table-hover mb-0">
          <thead>
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Status</th>
              <th>Views</th>
              <th>Published Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (blogs && blogs.length > 0) { %>
              <% blogs.forEach(blog => { %>
                <tr>
                  <td><strong><%= blog.title %></strong></td>
                  <td><span class="badge bg-purple"><%= blog.category %></span></td>
                  <td>
                    <span class="badge <%= blog.status === 'Published' ? 'bg-success' : 'bg-secondary' %>">
                      <%= blog.status %>
                    </span>
                  </td>
                  <td><%= blog.views %></td>
                  <td><%= new Date(blog.publishedDate).toLocaleDateString() %></td>
                  <td>
                    <a href="/admin/blogs/edit/<%= blog._id %>" class="btn btn-sm btn-outline-info me-1"><i class="fa-solid fa-pen"></i> Edit</a>
                    <button onclick="deleteBlog('<%= blog._id %>')" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center py-4 text-white-50">No blogs found in database. Create your first blog post!</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  async function deleteBlog(id) {
    if (!confirm('Are you sure you want to delete this blog post?')) return;
    try {
      const res = await fetch(`/api/blogs/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (res.ok && data.success) {
        window.location.reload();
      } else {
        alert(data.message || 'Error deleting blog');
      }
    } catch (err) {
      alert('Network error deleting blog');
    }
  }
</script>

</body>
</html>

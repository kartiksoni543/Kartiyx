<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Website & SEO Settings - Admin CMS</title>
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <link rel="stylesheet" href="/assets/css/font-awesome-pro.min.css">
  <style>
    body { background: #0b0512; color: #fff; }
    .sidebar { min-height: 100vh; background: #130a21; border-right: 1px solid rgba(168, 85, 247, 0.2); }
    .nav-link { color: #a0aec0; padding: 12px 20px; font-weight: 500; }
    .nav-link.active, .nav-link:hover { color: #c084fc; background: rgba(168, 85, 247, 0.1); border-radius: 8px; }
    .card-stat { background: #190e2b; border: 1px solid rgba(168, 85, 247, 0.2); border-radius: 16px; }
    .text-purple { color: #c084fc; }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 sidebar p-3">
      <h4 class="text-purple fw-bold mb-4">Kartik CMS</h4>
      <ul class="nav flex-column gap-2">
        <li class="nav-item"><a href="/admin/dashboard" class="nav-link"><i class="fa-solid fa-chart-line me-2"></i> Dashboard</a></li>
        <li class="nav-item"><a href="/admin/blogs" class="nav-link"><i class="fa-solid fa-newspaper me-2"></i> Blogs</a></li>
        <li class="nav-item"><a href="/admin/messages" class="nav-link"><i class="fa-solid fa-envelope me-2"></i> Inquiries</a></li>
        <li class="nav-item"><a href="/admin/settings" class="nav-link active"><i class="fa-solid fa-gears me-2"></i> Settings</a></li>
        <li class="nav-item mt-4"><a href="/admin/logout" class="nav-link text-danger"><i class="fa-solid fa-right-from-bracket me-2"></i> Logout</a></li>
      </ul>
    </div>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 p-4">
      <h2 class="mb-4">Global Site & SEO Settings</h2>

      <div class="card-stat p-4" style="max-width: 800px;">
        <div id="settings-alert" class="alert alert-success" style="display: none;"></div>

        <form id="settings-form">
          <div class="mb-3">
            <label class="form-label text-purple fw-bold">Site Name</label>
            <input type="text" name="siteName" class="form-control bg-dark text-white border-purple" value="<%= settings.siteName %>">
          </div>
          <div class="mb-3">
            <label class="form-label text-purple fw-bold">Global Meta Title</label>
            <input type="text" name="metaTitle" class="form-control bg-dark text-white border-purple" value="<%= settings.metaTitle %>">
          </div>
          <div class="mb-3">
            <label class="form-label text-purple fw-bold">Global Meta Description</label>
            <textarea name="metaDescription" class="form-control bg-dark text-white border-purple" rows="3"><%= settings.metaDescription %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label text-purple fw-bold">Keywords</label>
            <input type="text" name="keywords" class="form-control bg-dark text-white border-purple" value="<%= settings.keywords %>">
          </div>
          <div class="mb-3">
            <label class="form-label text-purple fw-bold">Receiver Contact Email</label>
            <input type="email" name="contactEmail" class="form-control bg-dark text-white border-purple" value="<%= settings.contactEmail %>">
          </div>

          <button type="submit" class="btn btn-purple px-4 py-2" id="save-settings-btn">Save Settings</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('settings-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const alertBox = document.getElementById('settings-alert');
    const saveBtn = document.getElementById('save-settings-btn');
    alertBox.style.display = 'none';
    saveBtn.disabled = true;
    saveBtn.innerText = 'Saving...';

    const payload = {
      siteName: this.siteName.value,
      metaTitle: this.metaTitle.value,
      metaDescription: this.metaDescription.value,
      keywords: this.keywords.value,
      contactEmail: this.contactEmail.value
    };

    try {
      const res = await fetch('/admin/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (res.ok && data.success) {
        alertBox.style.display = 'block';
        alertBox.innerText = 'Settings updated successfully!';
      } else {
        alert(data.message || 'Error updating settings');
      }
    } catch (err) {
      alert('Error connecting to server');
    } finally {
      saveBtn.disabled = false;
      saveBtn.innerText = 'Save Settings';
    }
  });
</script>

</body>
</html>
